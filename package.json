  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3002",
    "build": "next build && tsc --project tsconfig.server.json",
    "start": "node dist/server.js",
    "lint": "eslint app",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "migrate:create": "prisma migrate dev --create-only",
