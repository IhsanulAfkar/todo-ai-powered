    "migrate:prod": "prisma migrate deploy",
    "generate": "prisma generate",
    "migrate:reset": "prisma migrate reset --force",
    "seed": "tsx ./prisma/seeders/DatabaseSeeder.ts",
    "postinstall": "node ./postinstall.js"
  },
